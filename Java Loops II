import java.io.*;
import java.util.*;

public class Solution {
    
    static int computationA(int a, int b, int i) { return a + (int) Math.pow(2, i) * b; }

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc = new Scanner(System.in);
        
        int q = sc.nextInt();
        
        while (q > 0) {
            int a = sc.nextInt();
            int b = sc.nextInt();
            int n = sc.nextInt();
            
            int ans = a;
            
            for (int i = 0; i < n - 1; i++) {
                ans = computationA(ans, b, i);
                System.out.printf("%d ", ans);
            }
            System.out.println(computationA(ans, b, n - 1));
            
            q--;
        }
        
        sc.close();
    }
}
